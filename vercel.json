{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "build" } },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/admin$", "dest": "/api/admin.js" },
    { "src": "/api/admin/(.*)", "dest": "/api/admin.js?path=/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron-scan",
      "schedule": "0 10 * * *"
    }
  ]
}
